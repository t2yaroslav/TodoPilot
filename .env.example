# =============================================================================
# TodoPilot — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
# All variables are grouped by service.
# =============================================================================

# --- Database -----------------------------------------------------------------

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=todopilot
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/todopilot

# --- JWT ----------------------------------------------------------------------

JWT_SECRET=change-me-to-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# --- Email (SMTP for sending auth codes) -------------------------------------
# Gmail: enable 2FA, then create App Password
# https://myaccount.google.com/apppasswords

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASSWORD=app-password-here
SMTP_FROM=your@gmail.com

# --- Google OAuth (optional — leave empty to disable) -------------------------
# Create OAuth 2.0 Client ID (Web application) in Google Cloud Console:
# https://console.cloud.google.com/apis/credentials
# Add http://localhost:3000 to "Authorized JavaScript origins"
# Both values are the same Client ID string.

GOOGLE_CLIENT_ID=
VITE_GOOGLE_CLIENT_ID=

# --- AI Provider --------------------------------------------------------------
# Uses LiteLLM — switch model to change provider.
# OpenAI:   gpt-4o-mini, gpt-4o          https://platform.openai.com/api-keys
# Claude:   claude-sonnet-4-20250514      https://console.anthropic.com/settings/keys
# Deepseek: deepseek/deepseek-chat        https://platform.deepseek.com/api_keys
# Local:    ollama/llama3 (set LLM_API_BASE=http://ollama:11434)

LLM_MODEL=gpt-4o-mini
LLM_API_KEY=sk-your-key-here
LLM_API_BASE=
# LLM debug logging — logs model, tokens, cost, latency for every AI call
LLM_DEBUG=false

# --- Admin --------------------------------------------------------------------

ADMIN_EMAIL=your@email.com

# --- Frontend -----------------------------------------------------------------

VITE_API_URL=http://localhost:8000
